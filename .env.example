# Kopiere diese Datei nach .env und passe die Werte an.

# Zufälliger geheimer Schlüssel für JWT-Tokens (mind. 32 Zeichen)
# Generieren z.B. mit: openssl rand -hex 32
JWT_SECRET=aendern-auf-einen-langen-zufaelligen-string

# Port für das Backend (API)
PORT=8080

# Port für das Frontend (Web-UI)
UI_PORT=8090
